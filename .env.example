# Docker Compose example.
#
# Copy this file to .env for the self-contained Docker stack:
#   cp .env.example .env
#   docker compose up --build
#
# For direct host development with `bun run dev`, copy .env.host.example instead.
NODE_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
WORKER_PORT=3010

# Docker host interface for the web app port. Keep localhost by default.
# Set OSF_WEB_BIND_ADDRESS=0.0.0.0 to allow LAN access to http://<host-ip>:3000.
OSF_WEB_BIND_ADDRESS=127.0.0.1

DATABASE_URL=postgres://open_superforecaster:open_superforecaster@postgres:5432/open_superforecaster
REDIS_URL=redis://redis:6379

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=open_superforecaster
MINIO_SECRET_KEY=open-superforecaster-local-dev
MINIO_REGION=local
MINIO_BUCKET_ARTIFACTS=open-superforecaster-artifacts
MINIO_BUCKET_EVALS=open-superforecaster-evals
MINIO_BUCKET_EXPORTS=open-superforecaster-exports

DUCKDB_PATH=/data/duckdb/open-superforecaster.duckdb
ARTIFACTS_DIR=/data/artifacts
EXPORTS_DIR=/data/exports
EVALS_DIR=/data/evals
SMITHERS_STATE_DIR=/data/smithers

# Agent provider policy. Codex remains the default because the quickstart
# prerequisite is a Codex subscription. Add Claude/Pi/etc. by changing the
# purpose lists after creating their auth profiles under AGENT_AUTH_ROOT.
AGENT_AUTH_ROOT=/agent-auth
AGENT_AUTH_CONTAINER_ROOT=/agent-auth
AGENT_AUTH_HOST_ROOT=./data/agent-auth
AGENT_DEFAULT=codex:default
AGENT_STRUCTURED=codex:default
AGENT_RESEARCH=codex:default
AGENT_FORECAST=codex:default
AGENT_CRITIC=codex:default
AGENT_ALLOW_NATIVE_WEB=false

CODEX_CONTAINER_HOME=/agent-auth/codex/default
CODEX_HOME=/agent-auth/codex/default
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=xhigh
CODEX_AUTH_MODE=mount

# Claude Code is installed in the Docker image, but it is opt-in. Populate
# ./data/agent-auth/claude/default by running the setup commands in README.md,
# then add claude:default to the AGENT_* purpose lists above.
CLAUDE_CONFIG_DIR=/agent-auth/claude/default
# CLAUDE_MODEL=

# Other Smithers CLI providers can use the same auth-root convention once their
# binaries are installed in the image or available on the host.
# KIMI_SHARE_DIR=/agent-auth/kimi/default
# PI_PROVIDER=
# PI_MODEL=

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=open-superforecaster
