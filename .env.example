# Docker Compose example.
#
# Copy this file to .env for the self-contained Docker stack:
#   cp .env.example .env
#   docker compose up --build
#
# For direct host development with `bun run dev`, copy .env.host.example instead.
NODE_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
WORKER_PORT=3010

DATABASE_URL=postgres://open_superforecaster:open_superforecaster@postgres:5432/open_superforecaster
REDIS_URL=redis://redis:6379

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=open_superforecaster
MINIO_SECRET_KEY=open-superforecaster-local-dev
MINIO_REGION=local
MINIO_BUCKET_ARTIFACTS=open-superforecaster-artifacts
MINIO_BUCKET_EVALS=open-superforecaster-evals
MINIO_BUCKET_EXPORTS=open-superforecaster-exports

DUCKDB_PATH=/data/duckdb/open-superforecaster.duckdb
ARTIFACTS_DIR=/data/artifacts
EXPORTS_DIR=/data/exports
EVALS_DIR=/data/evals
SMITHERS_STATE_DIR=/data/smithers

# Agent engine, selectable per user (a mixed team can share this repo):
#   codex  -> Codex CLI (default; uses CODEX_HOME below)
#   claude -> Claude Code CLI (uses CLAUDE_CONFIG_DIR / your ~/.claude login)
AGENT_ENGINE=claude

CODEX_CONTAINER_HOME=/home/bun/.codex
CODEX_HOME=/home/bun/.codex
CODEX_MODEL=gpt-5.5
CODEX_AUTH_MODE=mount

# Claude Code engine (only used when AGENT_ENGINE=claude).
# Docker auth: the macOS Keychain isn't reachable inside the container, so provide
# a subscription token. Generate one on the host with:  claude setup-token
# then paste it below. Compose mounts ./data/claude as the container's Claude
# config dir (CLAUDE_CONTAINER_HOME) so login state + token refresh persist.
# CLAUDE_CODE_OAUTH_TOKEN=
# CLAUDE_MODEL=
CLAUDE_CONTAINER_HOME=/home/bun/.claude
# Give the Claude engine its native WebSearch/WebFetch tools on LIVE forecasts.
# Keep off for pastcasting/fixed-evidence eval (agent-side search leaks).
CLAUDE_WEB_SEARCH=on

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=open-superforecaster

# Leave CODEX_HOST_HOME empty to let docker-compose default to ${HOME}/.codex.
# Set it to an absolute host path only when your Codex login lives elsewhere.
CODEX_HOST_HOME=
