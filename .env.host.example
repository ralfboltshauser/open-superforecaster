# Direct host development example.
#
# Use this when running the app with Bun on the host:
#   cp .env.host.example .env
#   docker compose up -d postgres redis minio otel-collector prometheus tempo grafana
#   bun install
#   bun run dev
#
# The full self-contained Docker path uses .env.example instead.
NODE_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
WORKER_PORT=3010

DATABASE_URL=postgres://open_superforecaster:open_superforecaster@localhost:5432/open_superforecaster
REDIS_URL=redis://localhost:6379

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=open_superforecaster
MINIO_SECRET_KEY=open-superforecaster-local-dev
MINIO_REGION=local
MINIO_BUCKET_ARTIFACTS=open-superforecaster-artifacts
MINIO_BUCKET_EVALS=open-superforecaster-evals
MINIO_BUCKET_EXPORTS=open-superforecaster-exports

DUCKDB_PATH=./data/duckdb/open-superforecaster.duckdb
ARTIFACTS_DIR=./data/artifacts
EXPORTS_DIR=./data/exports
EVALS_DIR=./data/evals
SMITHERS_STATE_DIR=./data/smithers

# Agent engine, selectable per user (a mixed team can share this repo):
#   codex  -> Codex CLI (default; uses CODEX_HOME / your ~/.codex login)
#   claude -> Claude Code CLI (uses your ~/.claude login on the host)
AGENT_ENGINE=codex

# CODEX_HOME defaults to ${HOME}/.codex. Uncomment only if your Codex login lives elsewhere.
# CODEX_HOME=/absolute/path/to/.codex
CODEX_MODEL=gpt-5.5
CODEX_AUTH_MODE=mount

# Claude Code engine (only used when AGENT_ENGINE=claude).
# CLAUDE_CONFIG_DIR defaults to ${HOME}/.claude. Uncomment only if it lives elsewhere.
# CLAUDE_CONFIG_DIR=/absolute/path/to/.claude
# CLAUDE_MODEL=
# Give the Claude engine its native WebSearch/WebFetch tools on LIVE forecasts.
# Keep off for pastcasting/fixed-evidence eval (agent-side search leaks).
CLAUDE_WEB_SEARCH=off

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=open-superforecaster
