{
  "name": "open-superforecaster",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --cwd apps/web dev",
    "dev:marketing": "bun --cwd apps/marketing dev",
    "dev:worker": "bun --cwd apps/worker dev",
    "build": "bun run build:web && bun run build:marketing",
    "build:web": "bun --cwd apps/web build",
    "build:marketing": "bun --cwd apps/marketing build",
    "start": "bun --cwd apps/web start",
    "start:marketing": "bun --cwd apps/marketing preview",
    "check": "bun run typecheck && bun run lint && bun run test && bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "bun --cwd apps/web lint",
    "test": "bun test && bun run forecast:scripts:check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "smoke:local": "bun scripts/smoke-check.ts",
    "workflow:samples": "bun scripts/run-sample-workflows.ts",
    "forecast:ops": "bun scripts/forecast-ops-runner.ts",
    "forecast:update-due": "bun scripts/forecast-update-runner.ts",
    "forecast:resolve": "bun scripts/forecast-resolution-runner.ts",
    "forecast:performance": "bun scripts/forecast-performance-report.ts",
    "forecast:batches": "bun scripts/forecast-batch-index.ts",
    "forecast:attention": "bun scripts/forecast-attention-backlog.ts",
    "forecast:health": "bun scripts/forecast-batch-health.ts",
    "forecast:review": "bun scripts/forecast-review.ts",
    "forecast:calibration-proposals": "bun scripts/forecast-calibration-guard-proposals.ts",
    "forecast:calibration-validate": "bun scripts/forecast-calibration-guard-validation.ts",
    "forecast:calibration-default-plan": "bun scripts/forecast-calibration-guard-default-plan.ts",
    "forecast:scripts:check": "bun scripts/forecast-script-check.ts",
    "onboarding:check": "bun scripts/onboarding-check.ts",
    "object-storage:smoke": "bun scripts/object-storage-smoke.ts",
    "workflow:coverage": "bun scripts/workflow-coverage.ts",
    "duckdb:sync": "bun scripts/sync-duckdb.ts",
    "export-local": "bun scripts/export-local.ts",
    "cleanup-local": "bun scripts/cleanup-local.ts",
    "reset-local": "bun scripts/reset-local.ts",
    "clean": "rm -rf apps/web/.next"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.4-r.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.23.0",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "smithers-orchestrator": "0.27.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3"
  }
}
