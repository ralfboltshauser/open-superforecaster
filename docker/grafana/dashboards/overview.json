{
  "title": "Open Superforecaster Overview",
  "schemaVersion": 41,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "text",
      "title": "Local Observability",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "Prometheus scrapes `/metrics` from the local app. Metrics include task, Smithers run, benchmark run, benchmark case, workflow variant, Smithers token usage, source-bank, score, and resolution labels for local debugging."
      }
    },
    {
      "type": "stat",
      "title": "Running Tasks",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 3 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(open_superforecaster_tasks_total{status=\"running\"})"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "type": "stat",
      "title": "Benchmark Review Cases",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 3 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(open_superforecaster_benchmark_case_info{status=\"needs_review\"})"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "type": "stat",
      "title": "Product Resolutions",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 3 },
      "targets": [
        {
          "refId": "A",
          "expr": "open_superforecaster_resolutions_total{annulled=\"false\"}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "type": "stat",
      "title": "Mean Product Brier",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 3 },
      "targets": [
        {
          "refId": "A",
          "expr": "open_superforecaster_forecast_score_mean{score_type=\"brier\",source=\"manual_resolution\",target=\"aggregate\"}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "type": "timeseries",
      "title": "Task Counts By Status",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (open_superforecaster_tasks_total)"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "type": "timeseries",
      "title": "Benchmark Runs By Status",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status, eval_mode) (open_superforecaster_benchmark_runs_total)"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "type": "stat",
      "title": "Recent Smithers Tokens",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(open_superforecaster_smithers_token_total{token_type=\"total\"})"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "type": "stat",
      "title": "Recent Agent Calls",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(open_superforecaster_smithers_agent_calls_total)"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "type": "stat",
      "title": "Recent Output Tokens",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(open_superforecaster_smithers_token_total{token_type=\"output\"})"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "type": "timeseries",
      "title": "Smithers Tokens By Type",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 18 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (token_type) (open_superforecaster_smithers_token_total)"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "type": "table",
      "title": "Recent Task Correlation Labels",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 25 },
      "targets": [
        {
          "refId": "A",
          "expr": "open_superforecaster_task_info",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      }
    }
  ]
}
