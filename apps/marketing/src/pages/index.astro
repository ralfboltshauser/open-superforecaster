---
import ArchitectureDiagram from "../components/ArchitectureDiagram.astro"
import CopyBlock from "../components/CopyBlock.astro"
import LogoMark from "../components/LogoMark.astro"
import MiniDiagram from "../components/MiniDiagram.astro"
import Plate from "../components/Plate.astro"
import Base from "../layouts/Base.astro"

const deliverables = [
  ["1.1", "Source-backed probability", "Parallel researchers produce probabilities with rationale and citations.", "probability", "primary"],
  ["1.2", "Forecast artifact", "Each run leaves structured output that can be inspected, exported, and compared.", "artifact", "forecast"],
  ["1.3", "Trace bundle", "The question, evidence, attempts, aggregate, and workflow events stay replayable.", "trace", "primary"],
  ["1.4", "Benchmark evidence", "Local benchmark and pastcasting loops make workflow changes harder to hand-wave.", "score", "success"],
]

const useCases = [
  ["Forecast modes", "Binary, date, numeric, categorical, thresholded, and conditional questions.", "Will a named model beat a benchmark by Q4?", "probability", "/screenshots/forecast-renderer-binary.png"],
  ["Deep research fan-out", "Run parallel CodexAgent researchers and synthesize disagreements.", "What evidence changes the outlook for this market?", "fanout", "/screenshots/composer-home.png"],
  ["Table workflows", "Agent-map, classify, rank, merge, and dedupe rows with repeatable artifacts.", "Rank these companies by likely enterprise adoption.", "table", ""],
  ["Benchmark lab", "Score fixed-evidence and pastcasting runs before trusting a workflow variant.", "Did the new prompt improve Brier score?", "score", "/screenshots/benchmark-detail.png"],
  ["Decision briefs", "Turn evidence, distributions, and caveats into a reviewable local record.", "What should be re-run before acting?", "artifact", ""],
  ["Resolution loop", "Manually resolve product forecasts and watch calibration evidence accumulate.", "Was the event resolved and how did we score?", "trace", ""],
]

const trustQuestions = [
  "What was the exact question and resolution criterion?",
  "What evidence did the agents use?",
  "How did individual researchers disagree?",
  "What probability or distribution was emitted?",
  "Which artifacts, traces, and benchmarks support the result?",
  "What should be re-run before using this in a real decision?",
]
---

<Base>
  <main id="main">
    <section class="hero">
      <div class="hero-background">
        <div class="fs-vignette" style="position:absolute;inset:0"></div>
      </div>
      <div class="container hero-inner">
        <div class="hero-content">
          <div class="hero-logo-wrap">
            <span class="hero-logo-sparkles" aria-hidden="true"></span>
            <LogoMark class="hero-logo" />
          </div>
          <p class="fs-eyebrow" style="margin-top:1.6rem">search the future</p>
          <h1 class="fs-wordmark"><span>Open</span><span>Superforecaster</span></h1>
          <p class="hero-kicker">local forecasting appliance</p>
          <div class="fs-blueprint-line" style="margin:1.35rem auto 0;max-width:16rem"></div>
          <p class="hero-subtitle">
            An open-source, self-runnable forecasting appliance that turns a question about the future into parallel agent research,
            source-backed probabilities, artifacts, and trace bundles you can inspect locally.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="https://github.com/ralfboltshauser/open-superforecaster">View on GitHub</a>
            <a class="button secondary" href="#where-this-goes">Run it locally</a>
          </div>
          <div class="metric-strip" aria-label="Core principles">
            <div class="metric"><span class="metric-number">01</span><span class="metric-label">Evidence</span></div>
            <div class="metric"><span class="metric-number">02</span><span class="metric-label">Foresight</span></div>
            <div class="metric"><span class="metric-number">03</span><span class="metric-label">Trace</span></div>
          </div>
        </div>
      </div>
    </section>

    <div class="container plates">
      <Plate number="01" label="What It Is" description="A local cockpit for asking forecast questions and inspecting the full trust chain.">
        <div class="module-grid">
          {
            deliverables.map(([index, title, body, kind, accent]) => (
              <article class="module-card fs-panel">
                <span class="module-index">{index}</span>
                <MiniDiagram kind={kind} accent={accent} />
                <h3 class="module-title">{title}</h3>
                <p>{body}</p>
              </article>
            ))
          }
        </div>
      </Plate>

      <Plate number="02" label="Why Now" description="Forecasting is becoming a product surface, but trust still has to be earned run by run.">
        <p class="section-copy">
          Dynamic forecasting benchmarks and live markets make the gap visible: LLM forecasters are improving, scaffolded systems are getting
          closer to expert baselines, and market consensus remains a hard comparison. Open Superforecaster exists to keep that capability open,
          inspectable, and runnable on your own machine instead of hidden behind a black-box score.
        </p>
        <div class="citation-row" aria-label="Landscape references">
          <a class="citation-chip" href="https://arxiv.org/abs/2409.19839">ForecastBench</a>
          <a class="citation-chip" href="https://arxiv.org/abs/2511.07678">AIA Forecaster</a>
          <a class="citation-chip" href="https://evals.futuresearch.ai/">FutureSearch Evals</a>
          <span class="citation-chip">Prediction markets</span>
        </div>
        <p class="quote-line">Keep the capability open, inspectable, and runnable.</p>
      </Plate>

      <Plate number="03" label="Architecture" description="The appliance keeps forecasts, sources, traces, artifacts, and benchmarks inspectable locally.">
        <ArchitectureDiagram />
      </Plate>

      <Plate number="04" label="Use Cases" description="The same runtime can forecast questions, research decisions, process tables, and evaluate itself.">
        <div class="use-case-grid">
          {
            useCases.map(([title, body, prompt, kind, image]) => (
              <article class="demo-card fs-panel">
                <div class="demo-frame">
                  {image ? <img src={image} alt={`${title} screenshot`} loading="lazy" /> : <MiniDiagram kind={kind} />}
                </div>
                <h3>{title}</h3>
                <p>{body}</p>
                <p><span class="module-index">Demo:</span> {prompt}</p>
              </article>
            ))
          }
        </div>
      </Plate>

      <Plate number="05" label="Trust Model" description="Forecasting systems fail when assumptions, sources, or evaluation setup are hidden.">
        <div class="trust-list">
          {
            trustQuestions.map((question, index) => (
              <div class="trust-row">
                <span>{String(index + 1).padStart(2, "0")}</span>
                <p>{question}</p>
              </div>
            ))
          }
        </div>
      </Plate>

      <Plate number="06" label="Where This Goes" description="Open superforecasting should be usable by anyone with the Codex subscription they already own.">
        <p class="section-copy">
          This is not presented as a benchmark-grade oracle. The direction is practical open forecasting infrastructure: larger paired runs,
          clearer contamination checks, better calibration visibility, and a local workflow where research, evidence, and scores travel with every
          forecast. The goal is simple: ask a hard question, run durable agent work, and keep enough evidence to reason for yourself.
        </p>
        <CopyBlock />
        <p class="section-copy" style="margin-top:1.5rem">
          If you build on it or find a useful decision workflow, write to <a href="mailto:ralf@boltshauser.com">ralf@boltshauser.com</a>.
        </p>
      </Plate>
    </div>
  </main>

  <footer class="site-footer">
    <div class="container footer-keywords">
      <span>science.</span>
      <span>evidence.</span>
      <span>foresight.</span>
      <span class="open">open.</span>
      <span>superforecaster.openexp.dev</span>
    </div>
  </footer>
</Base>
