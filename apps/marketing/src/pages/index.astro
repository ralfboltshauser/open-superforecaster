---
import ArchitectureDiagram from "../components/ArchitectureDiagram.astro"
import CopyBlock from "../components/CopyBlock.astro"
import LogoMark from "../components/LogoMark.astro"
import Plate from "../components/Plate.astro"
import Screenshot from "../components/Screenshot.astro"
import SiteHeader from "../components/SiteHeader.astro"
import SourceGraphBackground from "../components/SourceGraphBackground.astro"
import Base from "../layouts/Base.astro"

const repo = "https://github.com/ralfboltshauser/open-superforecaster"

const metrics = [
  ["06", "Forecast modes"],
  ["03×", "Parallel researchers"],
  ["2", "Commands to run"],
  ["100%", "Local trust chain"],
]

const proofChain = [
  [
    "01",
    "Ask",
    "Pose a binary, numeric, date, categorical, thresholded, or conditional question with an explicit resolution rule.",
  ],
  [
    "02",
    "Fan out",
    "Three parallel CodexAgent researchers gather evidence independently, so disagreement stays visible instead of averaged away.",
  ],
  [
    "03",
    "Synthesize",
    "Findings aggregate into a probability or distribution with rationale, caveats, and inline source citations.",
  ],
  [
    "04",
    "Audit",
    "Sources, attempts, trace bundles, and benchmark scores persist as inspectable local records you can replay.",
  ],
]

const modes = [
  ["Binary", "P(event) as a calibrated yes/no probability."],
  ["Numeric", "A point estimate with a percentile range over a continuous quantity."],
  ["Date", "When an event resolves, expressed as a distribution over time."],
  ["Categorical", "Probabilities across a set of mutually exclusive outcomes."],
  ["Thresholded", "The odds a tracked metric crosses a specific threshold."],
  ["Conditional", "How one event shifts the probability of another."],
]

const trustChecks = [
  ["Question", "What exactly was forecast, and how does it resolve?"],
  ["Sources", "Which evidence moved the probability, and where did it come from?"],
  ["Disagreement", "Where did individual researchers diverge before synthesis?"],
  ["Trace", "Can the run be replayed from prompt to artifact bundle?"],
  ["Score", "Did the workflow survive local benchmark and pastcasting checks?"],
  ["Action", "What should be re-run before anyone trusts this in a real decision?"],
]

const exports = ["CSV", "Parquet", "Trace bundles", "Artifacts", "DuckDB tables"]

const stack = [
  ["Next.js", "Local cockpit UI"],
  ["Postgres", "Product ledger"],
  ["MinIO", "Artifact + trace storage"],
  ["DuckDB", "Local analytics"],
  ["Smithers", "Durable workflows"],
  ["CodexAgent", "Research fan-out"],
]
---

<Base>
  <SiteHeader />
  <main id="main">
    <section class="hero">
      <div class="hero-background">
        <SourceGraphBackground />
      </div>
      <div class="container hero-inner">
        <div class="hero-content">
          <LogoMark class="hero-logo" />
          <p class="fs-eyebrow" style="margin-top:1.4rem">search the future</p>
          <h1 class="fs-wordmark"><span>Open</span><span>Superforecaster</span></h1>
          <p class="hero-lede">Turn a hard question into cited probabilities you can audit.</p>
          <div class="fs-blueprint-line" style="margin:1.35rem auto 0;max-width:16rem"></div>
          <p class="hero-subtitle">
            A self-hosted forecasting appliance. It fans your question out to parallel research agents, aggregates their findings into a
            calibrated probability, and keeps every source, attempt, trace, and benchmark score on your own machine.
          </p>
          <div class="hero-actions">
            <a class="button primary" href={repo}>View on GitHub</a>
            <a class="button secondary" href="#run-locally">Run it locally</a>
          </div>
          <div class="metric-strip" aria-label="At a glance">
            {
              metrics.map(([number, label]) => (
                <div class="metric">
                  <span class="metric-number">{number}</span>
                  <span class="metric-label">{label}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <div class="container plates">
      <Plate
        number="01"
        label="Trust Chain"
        description="Don't trust a score — inspect the chain that produced it. Every run keeps its work."
      >
        <div class="chain-layout">
          {
            proofChain.map(([index, title, body]) => (
              <article class="chain-card">
                <span class="module-index">{index}</span>
                <div class="chain-node" aria-hidden="true" />
                <h3>{title}</h3>
                <p>{body}</p>
              </article>
            ))
          }
        </div>
      </Plate>

      <Plate
        number="02"
        label="Architecture"
        description="One local pipeline: question in, cited probability out, with every intermediate step persisted."
      >
        <ArchitectureDiagram />
        <div class="arch-legend">
          <article>
            <span class="module-index">01 · Input</span>
            <p>A question fans out to parallel agents that research sources, then synthesis emits a probability and forecast artifacts.</p>
          </article>
          <article>
            <span class="module-index">02 · Research</span>
            <p>Agents pull from the open web, arXiv, GitHub, reference data, and more — every citation is captured in the source bank.</p>
          </article>
          <article>
            <span class="module-index">03 · Trust chain</span>
            <p>Traces, benchmark cases, and a local store back the answer so any run can be replayed and re-scored.</p>
          </article>
        </div>
      </Plate>

      <Plate
        number="03"
        label="Cockpit"
        description="The real product surface: compose a question, launch a source-backed run, inspect the record."
      >
        <div class="surface-feature">
          <div class="surface-copy">
            <span class="fs-eyebrow">local appliance</span>
            <h3>Forecasts are records, not chat replies.</h3>
            <p>
              Ask a question and watch researchers gather evidence in real time. Every run becomes a local object: the question, its sources,
              individual attempts, the aggregate answer, artifacts, and the full workflow trace.
            </p>
          </div>
          <Screenshot
            src="/screenshots/composer-home.png"
            alt="Open Superforecaster composer: a forecast question ready to launch"
            url="localhost:3000"
            width="1440"
            height="980"
            eager={true}
          />
        </div>

        <div class="surface-record">
          <Screenshot
            src="/screenshots/forecast-renderer-binary.png"
            alt="Run detail: a binary forecast output with outcome bar, artifact rows, sources, and a scored forecast ledger"
            url="localhost:3000/runs/osf-resolution-smoke"
            width="1290"
            height="1330"
            crop={true}
          />
          <div class="surface-copy">
            <span class="fs-eyebrow">run detail</span>
            <h4>Every answer opens up.</h4>
            <p>
              Each run detail page surfaces the emitted probability, the artifact rows behind it, the source bank, and a forecast ledger of
              attempts, aggregates, and Brier + log scores. Export the trace bundle, CSV, or Parquet for deeper review.
            </p>
            <div class="chip-row">
              {exports.map((item) => <span class="chip">{item}</span>)}
            </div>
          </div>
        </div>
      </Plate>

      <Plate
        number="04"
        label="Forecast Modes"
        description="Six typed forecast modes, each with a dedicated renderer instead of a wall of freeform text."
      >
        <div class="mode-grid">
          {
            modes.map(([title, body], index) => (
              <article class="mode-card">
                <span class="module-index">{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </article>
            ))
          }
        </div>
      </Plate>

      <Plate
        number="05"
        label="Evaluation"
        description="Forecasting systems fail when their assumptions, evidence, or scoring setup stay hidden. This one makes them boringly visible."
      >
        <div class="surface-feature reverse">
          <div class="surface-copy">
            <span class="fs-eyebrow">benchmark lab</span>
            <h3>Score the workflow before you trust it.</h3>
            <p>
              Run benchmark and pastcasting loops against fixed evidence, then read the scorecard: mean Brier and log scores, baseline deltas,
              trace health, and explicit gate blockers that keep an unproven workflow from being promoted.
            </p>
          </div>
          <Screenshot
            src="/screenshots/benchmark-detail.png"
            alt="Benchmark Lab: a fixed-evidence scorecard with Brier and log scores, trace health, gate blockers, and case replay"
            url="localhost:3000/benchmarks/btf-2"
            width="1406"
            height="1400"
            crop={true}
          />
        </div>

        <div class="audit-grid">
          {
            trustChecks.map(([title, body], index) => (
              <article class="audit-row">
                <span>{String(index + 1).padStart(2, "0")}</span>
                <div>
                  <h3>{title}</h3>
                  <p>{body}</p>
                </div>
              </article>
            ))
          }
        </div>
      </Plate>

      <Plate
        number="06"
        label="Run Locally"
        description="Open forecasting infrastructure should be inspectable, forkable, and runnable by default."
      >
        <div class="run-panel">
          <div>
            <span class="fs-eyebrow">two commands</span>
            <h3>Bring up the appliance on your machine.</h3>
            <p>
              Postgres, object storage, the web cockpit, and the worker come up from the repo with Docker Compose, so the full trust chain stays
              local and inspectable. Requires a Codex subscription for the research agents.
            </p>
            <div class="stack-strip" aria-label="Technology stack">
              {
                stack.map(([name, role]) => (
                  <span class="stack-chip">
                    <strong>{name}</strong>
                    {role}
                  </span>
                ))
              }
            </div>
          </div>
          <CopyBlock />
        </div>
      </Plate>
    </div>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-keywords">
        <span>science.</span>
        <span>evidence.</span>
        <span>foresight.</span>
        <span class="open">open.</span>
      </div>
      <div class="footer-links">
        <a href={repo}>GitHub</a>
        <a href="mailto:ralf@boltshauser.com">Contact</a>
        <span>superforecaster.openexp.dev</span>
      </div>
    </div>
  </footer>
</Base>
