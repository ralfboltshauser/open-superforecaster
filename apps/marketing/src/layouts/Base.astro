---
import "../styles/global.css"

const title = "Open Superforecaster"
const description =
  "An open-source, self-runnable forecasting appliance for parallel agent research, source-backed probabilities, artifacts, traces, and local benchmark evidence."
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://superforecaster.openexp.dev").toString()
const ogImage = new URL("/og-image.png", Astro.site ?? "https://superforecaster.openexp.dev").toString()
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#05080f" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Open Superforecaster logo and title on a dark cyan forecasting graph background" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Open Superforecaster logo and title on a dark cyan forecasting graph background" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="site-shell">
      <div class="ambient-grid fs-graph-sheen" aria-hidden="true"></div>
      <slot />
    </div>
  </body>
</html>
