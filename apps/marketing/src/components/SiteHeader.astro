---
const repo = "https://github.com/ralfboltshauser/open-superforecaster"
const links = [
  ["Architecture", "#architecture"],
  ["Cockpit", "#cockpit"],
  ["Modes", "#forecast-modes"],
  ["Evaluation", "#evaluation"],
]
---

<header class="site-header">
  <div class="container site-header-inner">
    <a class="brand" href="#main" aria-label="Open Superforecaster">
      <img class="brand-mark" src="/logo.svg" alt="" width="28" height="28" aria-hidden="true" />
      <span class="brand-word">Open Superforecaster</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      {links.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
    <div class="site-header-actions">
      <a class="button primary compact" href={repo}>GitHub</a>
    </div>
  </div>
</header>
