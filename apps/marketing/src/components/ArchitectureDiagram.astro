---
const nodes = [
  "Next.js UI",
  "Route handlers",
  "Postgres ledger",
  "MinIO objects",
  "DuckDB analytics",
  "Smithers worker",
  "CodexAgent",
]
---

<div class="architecture-shell fs-panel">
  <svg class="architecture-diagram desktop-architecture" viewBox="0 0 980 430" role="img" aria-label="Open Superforecaster architecture">
    <defs>
      <marker id="arrow" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
        <path d="M0,0 L8,4 L0,8 Z" fill="oklch(0.74 0.14 152)"></path>
      </marker>
    </defs>
    <g fill="none" stroke="oklch(0.76 0.12 244 / 0.16)" stroke-width="1">
      <path d="M70 80C240 210 360 245 560 240C730 236 815 300 930 360"></path>
      <path d="M120 330C268 250 320 150 480 130C615 114 710 64 888 42"></path>
    </g>
    <g fill="oklch(0.08 0.012 257 / 0.88)" stroke="oklch(0.84 0.055 244 / 0.34)" stroke-width="1.4">
      <rect x="26" y="152" width="178" height="108" rx="8"></rect>
      <rect x="254" y="152" width="188" height="108" rx="8"></rect>
      <rect x="510" y="70" width="178" height="88" rx="8"></rect>
      <rect x="510" y="186" width="178" height="88" rx="8"></rect>
      <rect x="510" y="302" width="178" height="88" rx="8"></rect>
      <rect x="764" y="152" width="190" height="108" rx="8"></rect>
      <rect x="764" y="306" width="190" height="88" rx="8"></rect>
    </g>
    <g fill="none" stroke="oklch(0.74 0.14 152)" stroke-width="2" marker-end="url(#arrow)">
      <path d="M204 206H252"></path>
      <path d="M442 206C484 206 470 114 508 114"></path>
      <path d="M442 206H508"></path>
      <path d="M442 206C484 206 470 346 508 346"></path>
      <path d="M688 206H762"></path>
      <path d="M860 260V304"></path>
    </g>
    <g font-family="Atkinson Hyperlegible, system-ui, sans-serif">
      <g fill="oklch(0.94 0.012 252)" font-size="20" font-weight="700">
        <text x="68" y="190">Next.js UI</text>
        <text x="296" y="190">Route handlers</text>
        <text x="552" y="104">Postgres</text>
        <text x="552" y="220">MinIO</text>
        <text x="552" y="336">DuckDB</text>
        <text x="806" y="190">Smithers worker</text>
        <text x="806" y="340">CodexAgent</text>
      </g>
      <g fill="oklch(0.72 0.04 252)" font-size="13" letter-spacing="1.5">
        <text x="68" y="220">forecast composer</text>
        <text x="68" y="242">run cockpit</text>
        <text x="296" y="220">/api/runs</text>
        <text x="296" y="242">/api/benchmarks</text>
        <text x="552" y="130">tasks, rows, scores</text>
        <text x="552" y="246">trace bundles, CSV</text>
        <text x="552" y="362">local analytics mart</text>
        <text x="806" y="220">durable orchestration</text>
        <text x="806" y="242">retryable runs</text>
        <text x="806" y="366">research fan-out</text>
      </g>
    </g>
    <g>
      <circle class="glow-point" cx="62" cy="184" r="6" fill="var(--primary)"></circle>
      <circle class="glow-point" cx="290" cy="184" r="6" fill="var(--success)"></circle>
      <circle class="glow-point" cx="546" cy="98" r="6" fill="var(--primary)"></circle>
      <circle class="glow-point" cx="546" cy="214" r="6" fill="var(--success)"></circle>
      <circle class="glow-point" cx="546" cy="330" r="6" fill="var(--forecast)"></circle>
      <circle class="glow-point" cx="800" cy="184" r="6" fill="var(--success)"></circle>
      <circle class="glow-point" cx="800" cy="334" r="6" fill="var(--primary)"></circle>
    </g>
  </svg>
  <div class="mobile-architecture" aria-label="Open Superforecaster architecture">
    {nodes.map((node) => <div class="architecture-node fs-panel"><span class="dot"></span><span>{node}</span></div>)}
  </div>
</div>
